{
    "name": "expert-octo-garbanzo",
    "version": "1.0.0",
    "description": "OctoCAT Supply Chain Management System",
    "private": true,
    "workspaces": [
      "frontend"
    ],
  "scripts": {
    "build": "npm run build:frontend && npm run build:api",
    "build:frontend": "npm run build --workspace=frontend",
    "build:api": "node scripts/run-api.js build",
    "setup:api": "node scripts/run-api.js setup",
    "start:api": "node scripts/run-api.js start",
    "start:frontend": "npm run dev --workspace=frontend",
    "dev": "concurrently \"npm run start:api\" \"npm run start:frontend\"",
    "test": "concurrently \"npm run test:api\" \"npm run test --workspace=frontend\"",
    "test:api": "node scripts/run-api.js test",
    "test:frontend": "npm run test --workspace=frontend",
    "lint": "npm run lint --workspace=frontend"
  },
    "devDependencies": {
      "concurrently": "^6.2.1"
    },
    "license": "MIT",
    "engines": {
      "node": ">=18"
    }
}
